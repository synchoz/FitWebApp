# Copy this file to .env and fill in real values. .env itself is gitignored.

PORT=3001

# Local MySQL connection (utils/database.js falls back to these if DBDATABASE/
# DBUSERNAME/DBPASSWORD are unset — that's the normal path for local dev).
DB_LOCAL_DATABASE=fitwebapp
DB_LOCAL_USERNAME=root
DB_LOCAL_PASSWORD=
DBHOST=localhost

# Only needed if you want to override the local fallback above (e.g. staging/prod).
# DBDATABASE=
# DBUSERNAME=
# DBPASSWORD=

# Cloudinary (profile image upload) - get these from your Cloudinary dashboard.
CLOUDINARY_NAME=
CLOUDINARY_APIKEY=
CLOUDINARY_SECRET=
